// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @unique
  firstName String
  lastName String
  grade String
  phoneNumber String
  email String @unique
  city String
  state String
  parentFullName String
  parentPhoneNumber String
  parentEmail String
  classCode String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Station {
  id String @id
  name String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
