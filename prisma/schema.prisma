// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id String @id @unique
  firstName String
  lastName String
  grade String
  phoneNumber String
  email String @unique
  city String
  state String
  parentFullName String
  parentPhoneNumber String
  parentEmail String
  classCode String?

  myScore Score[] // one to many with score

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Station {
  id String @id
  name String
  choices Choices[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Choices {
  id String @id
  price BigInt
  station Station @relation(fields: [stationId], references: [id])
  stationId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  
}

model Job {
  id String @id
  name String
  description String @db.Text
  annualSalary BigInt
  grossMonthlySalary BigInt
  netMonthlySalary BigInt

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Room {
  id String @id

  roomInitialInformation RoomInitialInformation[] // one to many
  roomStationInformation RoomStationInformation[] // one to many
  roomInsuranceInformation RoomInsuranceInformation[] // one to many
  scoreInformation Score[] // one to many

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoomInitialInformation {
  id String @id
  playerId String
  jobId String
  roomId String  
  moneyInTheBank BigInt

  room Room @relation(fields: [roomId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoomStationInformation {
  id String @id
  playerId String
  roomId String
  stationId String
  moneyInTheBank BigInt
  purchaseAmount BigInt
  netMoneyInTheBank BigInt

  room Room @relation(fields: [roomId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Insurance {
  id String @id
  name String
  price BigInt

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  
}

model RoomInsuranceInformation {
  id String @id
  roomId String
  playerId String
  insuranceId String
  moneyInTheBank BigInt

  room Room @relation(fields: [roomId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  

}

model Score {
  id String @id
  roomId String
  playerId String
  score BigInt

  room Room @relation(fields: [roomId], references: [id])
  user Player @relation(fields: [playerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  
}