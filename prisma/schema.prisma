// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}
model User {
  id String @id
  userName String
  email String @unique
  password String
  apiToken String? @unique
  profileImage Json?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Player {
  id String @id @unique
  firstName String
  lastName String
  phoneNumber String
  email String?
  grade String?
  city String?
  // state String?
  // parentFullName String?
  // parentPhoneNumber String?
  // parentEmail String?
  // school String?
  
  myScore Score[] // one to many with score
  roomInitialInfo RoomInitialInformation[] // one to many with RoomInitialInformation
  roomInsuranceInfo RoomInsuranceInformation[]
  roomStationInfo RoomStationInformation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Station {
  id String @id
  name String
  bgImage Json?
  thumbnailImage Json?
  colorClass String?
  code String?
  choices Choices[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Choices {
  id String @id
  name String
  price Float?
  duration String?
  taxCredit Int?
  growthInPct Int?
  extraInfo String?
  station Station @relation(fields: [stationId], references: [id])
  stationId String
  image Json?

  internalChoices InternalChoices[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InternalChoices {
  id String @id

  name String
  price Float?
  duration String?

  choice Choices @relation(fields: [choiceId], references: [id])
  choiceId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Job {
  id String @id
  name String
  description String @db.Text
  annualSalary Float
  grossMonthlySalary Float
  netMonthlySalary Float

  roomInitialInformation RoomInitialInformation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Room {
  id String @id
  name String
  isActive Boolean @default(true)
  gameStarted Boolean @default(false)

  roomInitialInformation RoomInitialInformation[] // one to many
  roomStationInformation RoomStationInformation[] // one to many
  roomInsuranceInformation RoomInsuranceInformation[] // one to many
  scoreInformation Score[] // one to many

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model RoomInitialInformation {
  id String @id
  playerId String
  jobId String
  roomId String  
  moneyInTheBank Float?

  isSingle Boolean @default(false)

  job Job @relation(fields: [jobId], references: [id])
  room Room @relation(fields: [roomId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Define enum type BankType
enum BankType {
  piggy
  investment
  saving
}


model RoomStationInformation {
  id String @id
  playerId String
  roomId String
  stationId String
  choiceId String
  internalChoiceId String?
  currentAmount Float
  purchaseAmount Float
  taxCredit Float?
  growth Float?
  netAmount Float
  refunded Boolean @default(false)
  netAmountAfterRefunded Float?

  deposit Float?
  bankType BankType?
  
  room Room @relation(fields: [roomId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Insurance {
  id String @id
  name String
  price Int
  img Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  
}

model RoomInsuranceInformation {
  id String @id
  roomId String
  playerId String
  insuranceId String

  room Room @relation(fields: [roomId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  

}

model Score {
  id String @id
  roomId String
  playerId String
  score Int

  room Room @relation(fields: [roomId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt  
}